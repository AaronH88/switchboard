# project.yaml — Switchboard project configuration
# Lives in each project's workspace root. Defines repos, pipelines, and coding tools.

# Optional: directory containing project-specific agent definitions (.md files).
# Agents here override built-in switchboard agents of the same name.
# Path is relative to this project's workspace root.
# agents_dir: .claude/agents

# Repos in this project.
# Paths can be absolute or relative to this project's workspace root.
repos:
  - name: backend
    path: ./backend
    verify: "make test && make lint && make typecheck"
  - name: frontend
    path: ./frontend
    verify: "npm install && npm test && npm run lint"

# Named pipelines — each is a sequence of agents.
# /intake asks which pipeline to use when creating a feature DAG.
# Available built-in agents: tdd, interface, tests, development, integrate, verify, review
pipelines:
  dev:                                  # Full TDD development
    - tdd
    - interface
    - tests
    - development
    - verify
    - review

  quick-fix:                            # Fast bugfix
    - development
    - verify

  review:                               # Review a teammate's PR
    - review

  test-only:                            # Just add test coverage
    - tdd
    - tests
    - verify

# Coding tools — define how each tool is invoked.
# Template variables: {prompt_file} (path to prompt), {prompt} (inline text), {worktree} (path)
coding_tools:
  claude:
    command: ["claude", "-p", "{prompt_file}", "--output-format", "text", "--dangerously-skip-permissions"]
  # goose:
  #   command: ["goose", "run", "--text", "{prompt_file}"]
  # aider:
  #   command: ["aider", "--message-file", "{prompt_file}", "--yes-always"]

# Default tool for all agents
default_tool: claude

# Per-agent tool overrides (optional)
# agent_tools:
#   tests: goose
#   review: aider
